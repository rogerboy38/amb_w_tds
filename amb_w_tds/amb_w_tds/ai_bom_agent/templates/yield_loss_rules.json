{
  "version": "1.0",
  "description": "Yield and loss rules for BOM calculations",
  "created_date": "2026-02-17",
  
  "global_defaults": {
    "default_yield": 0.95,
    "max_acceptable_loss": 0.20,
    "min_acceptable_yield": 0.80
  },

  "process_yields": {
    "concentration": {
      "0227": {
        "yield_percentage": 0.95,
        "loss_percentage": 0.05,
        "loss_type": "evaporation",
        "notes": "5% water evaporation loss"
      },
      "0307": {
        "yield_percentage": 0.90,
        "loss_percentage": 0.10,
        "loss_type": "evaporation",
        "notes": "10% loss due to higher concentration ratio"
      }
    },
    "standardization": {
      "default": {
        "yield_percentage": 0.98,
        "loss_percentage": 0.02,
        "loss_type": "transfer_loss",
        "notes": "Minor transfer and mixing losses"
      }
    },
    "filtration": {
      "default": {
        "yield_percentage": 0.95,
        "loss_percentage": 0.05,
        "loss_type": "residue",
        "notes": "Filter cake and residue losses"
      }
    },
    "spray_drying": {
      "default": {
        "yield_percentage": 0.85,
        "loss_percentage": 0.15,
        "loss_type": "moisture_evaporation",
        "notes": "High moisture removal in drying"
      }
    },
    "packing": {
      "liquid": {
        "yield_percentage": 0.99,
        "loss_percentage": 0.01,
        "loss_type": "spillage",
        "notes": "Minor spillage during filling"
      },
      "powder": {
        "yield_percentage": 0.99,
        "loss_percentage": 0.01,
        "loss_type": "dust_loss",
        "notes": "Minor dust loss during packing"
      }
    }
  },

  "input_overages": {
    "description": "Extra input required to account for yields",
    "calculation": "input_qty = output_qty / yield_percentage",
    "examples": [
      {
        "process": "concentration",
        "output_needed": 100,
        "yield": 0.95,
        "input_required": 105.26
      },
      {
        "process": "spray_drying",
        "output_needed": 100,
        "yield": 0.85,
        "input_required": 117.65
      }
    ]
  },

  "cumulative_yields": {
    "0227_3step": {
      "description": "Cumulative yield for 0227 juice line (3 steps)",
      "steps": [
        {"step": 1, "name": "concentration", "yield": 0.95},
        {"step": 2, "name": "standardization", "yield": 0.98},
        {"step": 3, "name": "packing", "yield": 0.99}
      ],
      "cumulative_yield": 0.921,
      "notes": "0.95 × 0.98 × 0.99 = 0.921 (92.1% overall)"
    },
    "0307_4step": {
      "description": "Cumulative yield for 0307 powder line (4 steps)",
      "steps": [
        {"step": 1, "name": "concentration", "yield": 0.90},
        {"step": 2, "name": "filtration", "yield": 0.95},
        {"step": 3, "name": "spray_drying", "yield": 0.85},
        {"step": 4, "name": "packing", "yield": 0.99}
      ],
      "cumulative_yield": 0.719,
      "notes": "0.90 × 0.95 × 0.85 × 0.99 = 0.719 (71.9% overall)"
    }
  },

  "wip_allocation": {
    "description": "Rules for allocating excess production to WIP",
    "rules": [
      {
        "rule_id": "WIP1",
        "condition": "actual_yield > expected_yield",
        "action": "transfer_excess_to_wip",
        "warehouse": "Work In Progress - F"
      },
      {
        "rule_id": "WIP2",
        "condition": "is_shared_sfg == true",
        "action": "allow_wip_reuse",
        "max_age_days": 30
      }
    ]
  },

  "alerts": {
    "low_yield_threshold": 0.80,
    "high_loss_threshold": 0.20,
    "notification_recipients": ["production@ambwellness.com"]
  }
}
